{
  "name": "Gatherer",
  "allowedGoals": [
    "CollectFood",
    "CollectWood",
    "DepositResource",
    "ReportDepletion",
    "GetFood",
    "GetWood"
  ],
  "allowedActions": [
    "PickupFood",
    "PickupWood",
    "DepositResource",
    "ReportDepletion",
    "GetResource[Food]",
    "GetResource[Wood]"
  ],
  "priorityModifiers": {
    "CollectFood": 2.0,
    "CollectWood": 2.0,
    "DepositResource": 2.5,
    "Eat": 0.5,
    "Rest": 0.5
  },
  "distribution": {
    "rules": [
      { "match": "all", "conditions": [{ "type": "Food", "level": "low" }, { "type": "Food", "level": "known" }], "percent": 0.5 },
      { "match": "all", "conditions": [{ "type": "Wood", "level": "low" }, { "type": "Wood", "level": "known" }], "percent": 0.5 },
      { "default": true, "percent": 0 }
    ]
  },
  "color": "#4ec9b0"
}
